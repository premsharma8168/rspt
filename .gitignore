# ResearchMind AI - Global Gitignore

# Next.js / Node
frontend/.next/
frontend/node_modules/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/*.log
frontend/*.lock


# Python / FastAPI
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.venv
backend/venv
backend/env
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/uploads/*
!backend/uploads/.gitkeep

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Vector DB & Databases
qdrant_storage/
mongodb_data/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Docker
.docker/
